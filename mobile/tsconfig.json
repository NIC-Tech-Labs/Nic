{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": false,
		"baseUrl": ".",
    "paths": {
      "@screens/*": ["src/screens/*"],
      "@theme/*": ["src/theme/*"],
      "@routes/*": ["src/routes/*"],
      "@assets/*": ["src/assets/*"],
      "@components/*": ["src/components/*"]
    }
	}
}